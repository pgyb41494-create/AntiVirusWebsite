# Site-wide login (required to open dashboard, /control, etc.)
SITE_PASSWORD=your-site-password

# Railway API (server-side — used by control proxy routes)
API_URL=https://antivirusapi-production.up.railway.app

# Same BOT_API_KEY as AntiVirusAPI / AntiVirusBot (required for /control page)
BOT_API_KEY=your-bot-api-key

# Optional password for the website control page
CONTROL_PIN=

# Optional public API URL override for dashboard rewrites
# NEXT_PUBLIC_API_URL=https://antivirusapi-production.up.railway.app
